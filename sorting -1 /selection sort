// code for selection sort
#include<iostream>
using namespace std ;
int main(){
    int n ;
    cout << "  enter the4 array  size";
    cin >> n ;
    int a[n];
    cout << "enter the unsorted array ";
    for(int i=0;i<n;i++){
        cin >> a[i];
    }
    // selection sort from here
    for(int i=0;i<n-2;i++){
        int min = i;
        for(int j=i;j<n-1;j++){
            if(a[j]<a[min]){
                min =j;
            }
            int temp = a[i];
            a[i]=a[min];
            a[min]=temp;
        }
    }
    cout << " the sorted array is ";
    for(int i=0;i<n;i++){
        cout << a[i];
    }
} 
