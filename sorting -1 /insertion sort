#include<iostream>
using namespace std ;
int main(){
    int n ;
    cout  << "enter the size of array";
    cin >> n ;
    int a[n];
    cout << "enter the array";
    for(int i=0;i<n ;i++){
        cin >> a[i];
    }
    // implementing insertion sort
    for(int i=0;i<n-1;i++){
        int j=i;
        while(j>0 && a[j-1]>a[j]){
            int temp = a[j-1];
            a[j-1]=a[j];
            a[j]=temp ;
        }
    }
    cout << "the sorted array is :";
    for(int i=0;i<n ;i++){
        cout << a[i];
    }
}
