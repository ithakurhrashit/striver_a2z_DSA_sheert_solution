#include<iostream>
using namespace std ;
int main (){
    int n ;
    cout << "enter the size of array " ;
    cin >> n ;
    int a[n];
    cout << "enter the array ";
    for(int i=0;i<n;i++){
        cin >> a[i];
    }
    // implementing bubble sort
    for(int i= n-1 ; i>=1;i--){
        for(int j=0;j<=i-1;j++){
            if(a[j]>a[j+1]){
                int temp = a[j];
                a[j]=a[j+1];
                a[j+1]= temp ;
            }
        }
    }
    cout << "the soerted array is :";
    for(int i=0;i<n ;i++){
        cout << a[i];
    }
}
