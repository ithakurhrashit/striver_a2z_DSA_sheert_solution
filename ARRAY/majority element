class Solution {
public:
    int majorityElement(vector<int>& nums) {
        int ele;
        int n =nums.size();
        vector<int> hash ={0};
        for(int val : nums){
            hash[val]++;
        }
        for(int i=0;i<hash.size();i++){
            if(hash[i]>n/2){
             ele = nums[hash[i]];
            }
        }
        return ele;
        
    }
};
