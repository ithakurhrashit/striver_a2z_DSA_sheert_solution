// HASGING OF CHARECTERS 
#include<iostream>
using namespace std ;
int main(){
    string s ;
     cin >> s ;
     int hash[26]=0;
      for(int i=0;i<s.length();i++){
        hash[int(s[i])-97]+=1;
      }
      for(int i=0;i<26;i++){
        cout << char(i+97) << " "<< hash[i] << endl ;
      }

}
